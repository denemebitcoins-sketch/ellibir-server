{
  "name": "ellibir-server",
  "version": "1.0.0",
  "description": "51 (Elli Bir) Colyseus gerçek-zaman oyun sunucusu",
  "main": "src/index.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "ts-node --transpile-only src/index.ts",
    "dev": "ts-node-dev --transpile-only --respawn src/index.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "test:engine": "vitest run --root ..",
    "test": "npm run test:engine",
    "verify": "npm run typecheck && npm test"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.7",
    "colyseus": "0.17.10",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
